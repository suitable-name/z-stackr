{
	// Build matrix: {GUI, CLI, Trainer} × {generic, AVX2, AVX512, znver3, znver4} × {Windows, Linux},
	// plus PGO(+BOLT) chains for CLI/GUI at the bottom.
	//
	// Arch variants are driven by RUSTFLAGS (-C target-cpu=…):
	//   generic → baseline x86-64 (portable_simd falls back to SSE2/scalar)
	//   AVX2    → x86-64-v3  (AVX2 + FMA + BMI — Haswell+/Zen1+)
	//   AVX512  → x86-64-v4  (AVX-512 F/BW/CD/DQ/VL)
	//   znver3  → AMD Zen 3 tuned (AVX2)
	//   znver4  → AMD Zen 4 tuned (AVX-512)
	//
	// Each arch variant uses its own CARGO_TARGET_DIR (target/<arch>) so
	// switching variants never invalidates another variant's build cache.
	//
	// OS variants use explicit --target triples. Cross-compiling needs the
	// target installed (`rustup target add x86_64-unknown-linux-gnu` /
	// `x86_64-pc-windows-msvc`) plus a matching linker; the GUI (Slint/winit)
	// generally only builds for the host OS — run the matching task on the
	// matching machine (this tasks.json is shared between them).
	//
	// The project requires a NIGHTLY toolchain (portable_simd).
	"version": "2.0.0",
	"tasks": [
		// ── GUI (z-stackr-gui) ── Windows ─────────────────────────────────
		{
			"type": "shell",
			"label": "build GUI release — generic (Windows)",
			"command": "cargo build --release -p z-stackr-gui --target x86_64-pc-windows-msvc",
			"options": {
				"env": {
					"CARGO_TARGET_DIR": "target/generic"
				}
			},
			"problemMatcher": [
				"$rustc"
			],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "build GUI release — AVX2 (Windows)",
			"command": "cargo build --release -p z-stackr-gui --target x86_64-pc-windows-msvc",
			"options": {
				"env": {
					"RUSTFLAGS": "-C target-cpu=x86-64-v3",
					"CARGO_TARGET_DIR": "target/avx2"
				}
			},
			"problemMatcher": [
				"$rustc"
			],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "build GUI release — AVX512 (Windows)",
			"command": "cargo build --release -p z-stackr-gui --target x86_64-pc-windows-msvc",
