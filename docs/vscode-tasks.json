		// ════════════════════════════════════════════════════════════════════
		// PGO (+ BOLT on Linux) build chains — CLI & GUI.
		//
		// Prerequisites:
		//   * `rustup component add llvm-tools` and put its bin dir on PATH
		//     (…/lib/rustlib/<host>/bin/), or install a matching system LLVM,
		//     so `llvm-profdata` is available (its version must match rustc's
		//     LLVM major).
		//   * BOLT (Linux ONLY — it rewrites ELF; Windows PE is not supported):
		//     `llvm-bolt` from the llvm-bolt package.
		//   * All steps use the `release-perf` cargo profile (symbols + line
		//     tables kept — see the workspace Cargo.toml) and the dedicated
		//     target dir `target/pgo`, so normal build caches stay untouched.
		//
		// Run the numbered steps in order. Step 2 (the workload) should be
		// representative: real stacks, both fusion modes. The CLI workload
		// chains two runs with `&&` (needs bash or PowerShell 7+). The GUI
		// workload is interactive — the task launches the instrumented
		// binary; load a stack, align, fuse with Apex AND Relief, then quit
		// (profiles are written on exit).
		// ════════════════════════════════════════════════════════════════════

		// ── PGO + BOLT: CLI — znver4 (Linux) ──────────────────────────────
		{
			"type": "shell",
			"label": "PGO CLI znver4 Linux — 1: build instrumented",
			"command": "cargo build --profile release-perf -p z-stackr-cli --target x86_64-unknown-linux-gnu",
			"options": {
				"env": {
					"RUSTFLAGS": "-C target-cpu=znver4 -C profile-generate=${workspaceFolder}/target/pgo-data/cli-znver4",
					"CARGO_TARGET_DIR": "target/pgo"
				}
			},
			"problemMatcher": ["$rustc"],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "PGO CLI znver4 Linux — 2: run workload (apex + relief)",
			"command": "./target/pgo/x86_64-unknown-linux-gnu/release-perf/z-stackr --input-dir sample/test_subset_apex --output-file target/pgo-data/pgo_workload_apex.tif --mode apex --tile-size 512 && ./target/pgo/x86_64-unknown-linux-gnu/release-perf/z-stackr --input-dir sample/test_subset_relief --output-file target/pgo-data/pgo_workload_relief.tif --mode relief --tile-size 512",
			"problemMatcher": [],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "PGO CLI znver4 Linux — 3: merge profiles",
			"command": "llvm-profdata merge -o target/pgo-data/cli-znver4/merged.profdata target/pgo-data/cli-znver4",
			"problemMatcher": [],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "PGO CLI znver4 Linux — 4: build PGO-optimised (BOLT-ready)",
			"command": "cargo build --profile release-perf -p z-stackr-cli --target x86_64-unknown-linux-gnu",
			"options": {
				"env": {
					"RUSTFLAGS": "-C target-cpu=znver4 -C profile-use=${workspaceFolder}/target/pgo-data/cli-znver4/merged.profdata -C llvm-args=-pgo-warn-missing-function -C link-args=-Wl,--emit-relocs",
					"CARGO_TARGET_DIR": "target/pgo"
				}
			},
			"problemMatcher": ["$rustc"],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "BOLT CLI znver4 Linux — 5: instrument",
			"command": "llvm-bolt target/pgo/x86_64-unknown-linux-gnu/release-perf/z-stackr -instrument -o target/pgo/x86_64-unknown-linux-gnu/release-perf/z-stackr-inst --instrumentation-file=${workspaceFolder}/target/pgo-data/cli-znver4-bolt.fdata",
			"problemMatcher": [],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "BOLT CLI znver4 Linux — 6: run instrumented workload",
			"command": "./target/pgo/x86_64-unknown-linux-gnu/release-perf/z-stackr-inst --input-dir sample/test_subset_apex --output-file target/pgo-data/bolt_workload_apex.tif --mode apex --tile-size 512 && ./target/pgo/x86_64-unknown-linux-gnu/release-perf/z-stackr-inst --input-dir sample/test_subset_relief --output-file target/pgo-data/bolt_workload_relief.tif --mode relief --tile-size 512",
			"problemMatcher": [],
			"group": "build"
		},
		{
			"type": "shell",
			"label": "BOLT CLI znver4 Linux — 7: optimise layout (→ z-stackr-bolt)",
			"command": "llvm-bolt target/pgo/x86_64-unknown-linux-gnu/release-perf/z-stackr -o target/pgo/x86_64-unknown-linux-gnu/release-perf/z-stackr-bolt --data=target/pgo-data/cli-znver4-bolt.fdata -reorder-blocks=ext-tsp -reorder-functions=hfsort -split-functions -split-all-cold -icf=1 -dyno-stats",
			"problemMatcher": [],
			"group": "build"
		},

		// ── PGO + BOLT: GUI — znver4 (Linux) ──────────────────────────────
		{
			"type": "shell",
			"label": "PGO GUI znver4 Linux — 1: build instrumented",
