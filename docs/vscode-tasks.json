			"options": {
				"env": {
					"RUSTFLAGS": "-C target-cpu=znver4 -C profile-use=${workspaceFolder}/target/pgo-data/gui-znver4/merged.profdata -C llvm-args=-pgo-warn-missing-function -C link-args=-Wl,--emit-relocs",
					"CARGO_TARGET_DIR": "target/pgo"
				}
			},
			"problemMatcher": ["$rustc"],
			"group": "build"
		},
		{
